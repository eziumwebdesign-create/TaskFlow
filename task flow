<script>
let tasks = [
  { id: 1, title: "Set up PostgreSQL database schema", priority: "high", category: "Work", done: false, date: today() },
  { id: 2, title: "Build REST API endpoints for task CRUD", priority: "high", category: "Work", done: false, date: today() },
  { id: 3, title: "Implement drag-and-drop on task board", priority: "medium", category: "Work", done: true, date: today() },
  { id: 4, title: "Review algorithms for technical interview", priority: "high", category: "Study", done: false, date: today() },
  { id: 5, title: "Go for a 30-minute run", priority: "low", category: "Health", done: false, date: today() },
  { id: 6, title: "Call mom this weekend", priority: "medium", category: "Personal", done: false, date: today() },
];

let nextId = 7;
let currentView = 'all';
let currentFilter = 'all';
let dragSrc = null;

function today() {
  return new Date().toISOString().split('T')[0];
}

function addTask() {
  const input = document.getElementById('task-input');
  const title = input.value.trim();
  if (!title) return;
  tasks.unshift({
    id: nextId++,
    title,
    priority: document.getElementById('priority-select').value,
    category: document.getElementById('category-select').value,
    done: false,
    date: today()
  });
  input.value = '';
  render();
}

function toggleTask(id) {
  const t = tasks.find(t => t.id === id);
  if (t) t.done = !t.done;
  render();
}

function deleteTask(id) {
  tasks = tasks.filter(t => t.id !== id);
  render();
}

function setView(view, el) {
  currentView = view;
  document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  const titles = { all: 'All Tasks', today: "Today's Tasks", done: 'Completed', Work: 'Work', Personal: 'Personal', Study: 'Study', Health: 'Health' };
  document.getElementById('view-title').textContent = titles[view] || view;
  render();
}

function setFilter(filter, el) {
  currentFilter = filter;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  render();
}

function getViewedTasks() {
  let list = [...tasks];
  if (currentView === 'today') list = list.filter(t => t.date === today());
  else if (currentView === 'done') list = list.filter(t => t.done);
  else if (['Work','Personal','Study','Health'].includes(currentView)) list = list.filter(t => t.category === currentView);
  if (currentFilter === 'active') list = list.filter(t => !t.done);
  else if (currentFilter === 'done') list = list.filter(t => t.done);
  else if (currentFilter === 'high') list = list.filter(t => t.priority === 'high');
  return list;
}

function render() {
  updateCounts();
  updateStats();
  const list = document.getElementById('task-list');
  const viewed = getViewedTasks();
  if (viewed.length === 0) {
    list.innerHTML = `<div class="empty"><div class="empty-icon">✦</div>No tasks here. Add one above.</div>`;
    return;
  }
  list.innerHTML = viewed.map(t => `
    <div class="task-card ${t.done ? 'done' : ''}" draggable="true" data-id="${t.id}"
         ondragstart="dragStart(event)" ondragover="dragOver(event)" ondrop="drop(event)" ondragleave="dragLeave(event)">
      <div class="task-check ${t.done ? 'checked' : ''}" onclick="toggleTask(${t.id})"></div>
      <div class="task-body">
        <div class="task-title">${escHtml(t.title)}</div>
        <div class="task-meta">
          <span class="tag tag-${t.priority}">${t.priority}</span>
          <span class="tag tag-cat">${t.category}</span>
          <span class="task-date">${t.date}</span>
        </div>
      </div>
      <div class="task-actions">
        <button class="icon-btn" onclick="deleteTask(${t.id})" title="Delete">✕</button>
      </div>
    </div>
  `).join('');
}

function updateCounts() {
  document.getElementById('count-all').textContent = tasks.length;
  document.getElementById('count-today').textContent = tasks.filter(t => t.date === today()).length;
  document.getElementById('count-done').textContent = tasks.filter(t => t.done).length;
  ['Work','Personal','Study','Health'].forEach(c => {
    document.getElementById('count-' + c).textContent = tasks.filter(t => t.category === c).length;
  });
}

function updateStats() {
  document.getElementById('stat-total').textContent = tasks.length;
  document.getElementById('stat-done').textContent = tasks.filter(t => t.done).length;
  document.getElementById('stat-pending').textContent = tasks.filter(t => !t.done).length;
  document.getElementById('stat-high').textContent = tasks.filter(t => t.priority === 'high' && !t.done).length;
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// DRAG AND DROP
function dragStart(e) {
  dragSrc = e.currentTarget;
  e.currentTarget.classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/plain', e.currentTarget.dataset.id);
}

function dragOver(e) {
  e.preventDefault();
  e.currentTarget.classList.add('drag-over');
  return false;
}

function dragLeave(e) { e.currentTarget.classList.remove('drag-over'); }

function drop(e) {
  e.preventDefault();
  const fromId = parseInt(e.dataTransfer.getData('text/plain'));
  const toId = parseInt(e.currentTarget.dataset.id);
  if (fromId === toId) return;
  const fi = tasks.findIndex(t => t.id === fromId);
  const ti = tasks.findIndex(t => t.id === toId);
  const [moved] = tasks.splice(fi, 1);
  tasks.splice(ti, 0, moved);
  e.currentTarget.classList.remove('drag-over');
  render();
}

// CLOCK
function updateClock() {
  document.getElementById('clock').textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}
setInterval(updateClock, 1000);
updateClock();

render();
</script>
